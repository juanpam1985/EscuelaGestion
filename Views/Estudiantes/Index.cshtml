@model IEnumerable<Estudiante>
@{
    ViewData["Title"] = "Estudiantes";
}

<h2>Estudiantes</h2>
<p><a asp-action="Create">Nuevo estudiante</a></p>

<table>
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Fecha de nacimiento</th>
            <th>Grado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Nombre</td>
            <td>@item.Apellido</td>
            <td>@item.FechaNacimiento.ToString("yyyy-MM-dd")</td>
            <td>@item.Grado</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.EstudianteId">Editar</a> |
                <a asp-action="Details" asp-route-id="@item.EstudianteId">Detalle</a> |
                <a asp-action="Delete" asp-route-id="@item.EstudianteId">Eliminar</a>
            </td>
        </tr>
    }
    </tbody>
</table>
