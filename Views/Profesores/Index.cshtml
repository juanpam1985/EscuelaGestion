@model IEnumerable<Profesor>
@{
    ViewData["Title"] = "Profesores";
}

<h2>Profesores</h2>
<p><a asp-action="Create">Nuevo profesor</a></p>

<table>
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Especialidad</th>
            <th>Email</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Nombre</td>
            <td>@item.Apellido</td>
            <td>@item.Especialidad</td>
            <td>@item.Email</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ProfesorId">Editar</a> |
                <a asp-action="Details" asp-route-id="@item.ProfesorId">Detalle</a> |
                <a asp-action="Delete" asp-route-id="@item.ProfesorId">Eliminar</a>
            </td>
        </tr>
    }
    </tbody>
</table>
